# Google OAuth (Desktop app client) credentials for the Organizer.
# 1. Copy this file to ".env"  ->  cp .env.example .env
# 2. Paste the values from your Google Cloud "Desktop app" OAuth client.
# .env is git-ignored and never committed.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth scopes requested at sign-in. Read-only to start (Phase 2);
# we widen these when we add compose/event-create later.
GOOGLE_SCOPES=openid email https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly
