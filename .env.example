# Google OAuth (Desktop app client) credentials for the Organizer.
# 1. Copy this file to ".env"  ->  cp .env.example .env
# 2. Paste the values from your Google Cloud "Desktop app" OAuth client.
# .env is git-ignored and never committed.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth scopes requested at sign-in. gmail.modify covers read + archive/label/
# trash/mark-read; gmail.send covers replies/forwards; calendar.readonly is Phase 2c.
GOOGLE_SCOPES=openid email https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.readonly

# Anthropic Claude API key for the in-app reply assistant (usage-billed, separate
# from Claude Code). Starts with sk-ant-. Leave blank to disable the assistant.
ANTHROPIC_API_KEY=
