# ── Organizer cloud server configuration ──────────────────────────────────────
# Copy to .env for local dev, or set these as environment variables on Render.
# NEVER commit a real .env — it is gitignored.

# Public base URL of the deployment (no trailing slash).
# Local dev: http://localhost:3000 ; Render: https://<your-app>.onrender.com
APP_URL=http://localhost:3000
PORT=3000

# Comma/space separated Google emails allowed to sign in. Lock this down!
ALLOWED_EMAILS=michael.a.balk@gmail.com

# Long random string — signs the login session + OAuth-state cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Long random string — AES-256-GCM key encrypting OAuth tokens at rest.
ORGANIZER_ENCRYPTION_KEY=

# Where the JSON data + tokens live. On Render, point this at the mounted disk.
ORGANIZER_DATA_DIR=

# ── Google OAuth (Web application client) ─────────────────────────────────────
# Create at console.cloud.google.com → Credentials → OAuth client → "Web application".
# Authorized redirect URIs MUST include BOTH:
#   <APP_URL>/auth/login/callback     (sign-in / identity)
#   <APP_URL>/auth/google/callback    (connecting Gmail/Calendar accounts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override default scopes (space-separated). Leave unset to use defaults.
# GOOGLE_SCOPES=

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: ANTHROPIC_MODEL=claude-opus-4-8

# ── Zoom (Server-to-Server OAuth) — optional, for Zoom meeting creation ────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
